@startuml
skinparam classAttributeIconSize 0
skinparam maxMessageSize 150

' Define interfaces and classes
class Client {
}

class Invoker {
  - command: Command
  + setCommand(cmd: Command)
  + executeCommand()
}

interface Command <<interface>> {
  + execute()
  + undo()
}

class ConcreteCommand {
  - receiver: Receiver
  + ConcreteCommand(r: Receiver)
  + execute()
  + undo()
}

class Receiver {
  + action()
}

' Define relationships
Client ..> ConcreteCommand : " creates"
Client --> Receiver : " locates"
Invoker o-> Command : " stores"
Command <|.. ConcreteCommand : " implements"
ConcreteCommand --> Receiver : " invokes action() on"

' Add notes
note right of ConcreteCommand::execute
  receiver.action()
end note

note right of Invoker::executeCommand
  command.execute()
end note
@enduml