@startuml
skinparam classAttributeIconSize 0
skinparam maxMessageSize 150

' Define the Visitor interface
abstract class Visitor {
  + VisitConcreteElementA(ConcreteElementA)
  + VisitConcreteElementB(ConcreteElementB)
}

' Define Concrete Visitors
class ConcreteVisitor1 {
  + VisitConcreteElementA(ConcreteElementA)
  + VisitConcreteElementB(ConcreteElementB)
}

class ConcreteVisitor2 {
  + VisitConcreteElementA(ConcreteElementA)
  + VisitConcreteElementB(ConcreteElementB)
}

' Define the Object Structure and Element Interface
class ObjectStructure {
}

abstract class Element {
  + Accept(Visitor)
}

' Define Concrete Elements
class ConcreteElementA {
  + Accept(Visitor v)
  + OperationA()
}

class ConcreteElementB {
  + Accept(Visitor v)
  + OperationB()
}

class Client {
}

' Relationships
Client -right-> Visitor : " creates >"
Client -down-> ObjectStructure : " traverses >"
ObjectStructure -right-> "*" Element : " maintains >"

Visitor <|-- ConcreteVisitor1 : " implements"
Visitor <|-- ConcreteVisitor2 : " implements"

Element <|-- ConcreteElementA : " implements"
Element <|-- ConcreteElementB : " implements"

' Double Dispatch Interactions
ConcreteElementA .right.> Visitor : " dispatches to >"
ConcreteElementB .up.> Visitor : " dispatches to >"

' Notes for Logic Explanation
note bottom of ConcreteElementA
  **Accept(Visitor v)**
  ""v->VisitConcreteElementA(this);""
  (Passes itself back to the visitor)
end note

note bottom of ConcreteVisitor1
  **VisitConcreteElementA(ConcreteElementA e)**
  Executes specific algorithm for Element A.
  State is accumulated in the Visitor.
end note

@enduml
