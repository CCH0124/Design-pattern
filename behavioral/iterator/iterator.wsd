@startuml
skinparam classAttributeIconSize 0
skinparam maxMessageSize 150

' Define Interfaces
interface Aggregate <<interface>> {
  + createIterator(): Iterator
}

interface Iterator <<interface>> {
  + first()
  + next()
  + isDone(): boolean
  + currentItem(): Object
}

' Define Concrete Classes
class ConcreteAggregate {
  - elements
  + createIterator(): Iterator
}

class ConcreteIterator {
  - aggregate: ConcreteAggregate
  - currentPosition: int
  + first()
  + next()
  + isDone(): boolean
  + currentItem(): Object
}

class Client {
}

' Relationships
Aggregate <|.. ConcreteAggregate : " implements"
Iterator <|.. ConcreteIterator : " implements"

Client -> Aggregate : " requests iterator"
Client -> Iterator : " traverses elements"

ConcreteAggregate .right.> ConcreteIterator : " instantiates"
ConcreteIterator -left-> ConcreteAggregate : " keeps track of current position"

note bottom of ConcreteAggregate
  **createIterator()** implementation:
  ""return new ConcreteIterator(this)""
end note

note bottom of ConcreteIterator
  Implements the traversal logic 
  and maintains the current 
  position in the traversal 
  of the aggregate.
end note

@enduml
