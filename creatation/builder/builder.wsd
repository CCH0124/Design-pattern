@startuml
skinparam classAttributeIconSize 0
skinparam maxMessageSize 150

' Define the Director
class Director {
  - builder: Builder
  + Construct()
}

' Define the abstract Builder interface
interface Builder <<interface>> {
  + BuildPartA()
  + BuildPartB()
  + BuildPartC()
  + GetResult(): Product
}

' Define the Concrete Builder
class ConcreteBuilder {
  - product: Product
  + BuildPartA()
  + BuildPartB()
  + BuildPartC()
  + GetResult(): Product
}

' Define the complex Product
class Product {
  ' Complex internal representation
}

' Define the Client
class Client {
}

' Relationships
Client .right.> Director : " configures with Builder"
Client .down.> ConcreteBuilder : " creates"
Director o-right-> Builder : " delegates to"
Builder <|.. ConcreteBuilder : " implements"
ConcreteBuilder .right.> Product : " builds & returns"

' Notes for operational logic
note bottom of Director
  **Director::Construct()**
  ""for all objects in structure {""
  ""  builder->BuildPart();""
  ""}""
end note

note bottom of ConcreteBuilder
  Builds the product's internal
  representation and provides an
  interface for retrieving it.
end note

@enduml
