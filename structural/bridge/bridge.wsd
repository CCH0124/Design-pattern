@startuml
skinparam classAttributeIconSize 0
skinparam maxMessageSize 150

' Define the Client
class Client {
}

' The Abstraction defines the abstraction's interface
class Abstraction {
  - imp: Implementor
  + Operation()
}

' RefinedAbstraction extends the interface
class RefinedAbstraction {
  + OtherOperation()
}

' Implementor defines the interface for implementation classes
interface Implementor <<interface>> {
  + OperationImp()
}

' ConcreteImplementors implement the Implementor interface
class ConcreteImplementorA {
  + OperationImp()
}

class ConcreteImplementorB {
  + OperationImp()
}

' Relationships
Client -right-> Abstraction : " Uses >"
Abstraction o-right-> Implementor : " Maintains a reference to \n (The Bridge)"
Abstraction <|-- RefinedAbstraction : " Extends"
Implementor <|.. ConcreteImplementorA : " Implements"
Implementor <|.. ConcreteImplementorB : " Implements"

' Note explaining the forwarding/delegation
note bottom of Abstraction
  **Abstraction::Operation()**
  Implementation delegates the request:
  ""imp->OperationImp();""
end note

@enduml
