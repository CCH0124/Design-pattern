@startuml
title 轉接器模式 (Adapter Pattern) - 電壓轉換系統

' --- 樣式設定 ---
skinparam classAttributeIconSize 0
skinparam monochrome false
skinparam packageStyle rectangle
skinparam class {
BackgroundColor White
ArrowColor #d35400
BorderColor #e67e22
}

' ==========================================
' 1. 類別轉接器模式 (Class Adapter)
' 使用繼承 (Inheritance) 來連結 Adaptee
' ==========================================
package "類別轉接器 (Class Adapter)" {
class "Voltage220V" as C_Adaptee {
+ output220V(): int
}

interface "IVoltage5V" as C_Target {
    + {abstract} output5V(): int
}

class "VoltageAdapter" as C_Adapter {
    + output5V(): int
}

class "Phone" as C_Client {
    + charging(i: IVoltage5V): void
}


' 關係連線
C_Adapter -up-|> C_Adaptee : 繼承 (Inheritance)
C_Adapter .up.|> C_Target : 實作 (Implementation)
C_Client ..> C_Target : 依賴 (Dependency)


}
@enduml